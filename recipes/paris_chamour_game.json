{
  "project_title": "Make this like a premium video game quest about asking for chamour in Fr",
  "brand": "hamsa_nomads",
  "renderer": "remotion",
  "output": {
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "duration_sec": 25,
    "format": "mp4"
  },
  "input_video": {
    "src": "",
    "crop": "vertical_center_face",
    "remove_silence": false
  },
  "style": {
    "name": "passport_stamp",
    "tone": "warm, human, grounded, documentary",
    "brand_identity": "hamsa_nomads"
  },
  "logo": {
    "enabled": true,
    "position": "top_center",
    "watermark": false,
    "path": "assets/brand/hamsa-logo.png",
    "fallback_text": "Hamsa Nomads"
  },
  "transcription": {
    "mode": "auto",
    "model": "base",
    "language": "auto"
  },
  "auto_cut": {
    "enabled": false,
    "silence_threshold_db": -35,
    "min_silence_duration_sec": 0.7,
    "keep_silence_sec": 0.25
  },
  "intro_card": {
    "enabled": true,
    "style": "premium_editorial",
    "duration_sec": 1.8,
    "label": "PARIS NOTE",
    "headline": "Ask like a local",
    "subheadline": "Chamour, context, and confidence",
    "motif": "imperfect_route_line"
  },
  "caption_system": {
    "type": "animated_dialogue_box",
    "position": "lower_third",
    "max_words_per_caption": 6,
    "box_style": "parchment",
    "theme": "premium",
    "highlight_keywords": [
      "France",
      "Paris",
      "chamour"
    ],
    "keyword_highlights": []
  },
  "overlays": [
    {
      "type": "wrong_vs_right",
      "start_sec": 2.0,
      "duration_sec": 3.0,
      "wrong": "WRONG WORD",
      "right": "LOCAL TIP"
    },
    {
      "type": "passport_stamp",
      "start_sec": 3.2,
      "duration_sec": 0.8,
      "text": "HAMSA APPROVED"
    }
  ],
  "motion": {
    "punch_in_on_hook": true,
    "punch_in_on_keywords": true,
    "subtle_zoom_amount": 1.08,
    "caption_pop": true,
    "avoid_cheap_transitions": true
  },
  "transitions": [
    {
      "type": "game_quest_banner_reveal",
      "start_sec": 1.5,
      "duration_sec": 0.35
    },
    {
      "type": "passport_stamp_pop",
      "start_sec": 3.2,
      "duration_sec": 0.35
    },
    {
      "type": "route_line_wipe",
      "start_sec": 1.5,
      "duration_sec": 0.35
    },
    {
      "type": "parchment_card_slide",
      "start_sec": 4.0,
      "duration_sec": 0.35
    }
  ],
  "section_cards": [
    {
      "title": "PARIS QUEST",
      "start_sec": 1.5,
      "duration_sec": 0.8
    },
    {
      "title": "WRONG WORD",
      "start_sec": 2.0,
      "duration_sec": 0.7
    }
  ],
  "freeze_frames": [
    {
      "time_sec": 3.2,
      "duration_sec": 0.5,
      "overlay": "Passport stamp moment"
    }
  ],
  "thumbnail": {
    "enabled": true,
    "time_sec": 1.5,
    "headline": "Make this like a premium video game ques",
    "style": "passport_stamp"
  },
  "cta": {
    "enabled": true,
    "start_sec": 22,
    "text": "Follow Hamsa Nomads for Jewish travel tips in France",
    "style": "clean_brand_end"
  }
}